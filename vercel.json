{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/analyze.ts": {
      "maxDuration": 60,
      "includeFiles": "prompts/**"
    },
    "api/generate-image.ts": { "maxDuration": 60 }
  }
}
